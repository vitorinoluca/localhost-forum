DATABASE_URL=
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false

PORT=4000

# Log de acceso HTTP en consola (morgan). false = no volcar cada GET/POST en logs de Render.
# HTTP_ACCESS_LOG=false

# Log de intentos de inicio de sesion (linea [auth] en consola). false = desactivar.
# AUTH_LOGIN_LOG=false

# URL del SPA (la que ves en la barra del navegador). En Render con front y API separados:
# NO pongas aqui la URL del backend (ej. localhost-forum.onrender.com).
# Ejemplo front en otro subdominio que el API:
# CLIENT_ORIGIN=https://localhost-forum-1.onrender.com
# El build del cliente debe tener VITE_API_URL=https://TU-BACKEND.onrender.com (sin barra final).
CLIENT_ORIGIN=http://localhost:5174

# Mas origenes permitidos (coma separada): previews, otro dominio, etc.
# CLIENT_ORIGINS=https://staging.example.com
# Si el front esta en muchos subdominios (ej. previews en Render), sin escribirlos todos:
# CLIENT_ORIGIN_REGEX=^https://[a-z0-9-]+\.onrender\.com$
# Ver en logs que Origin llego mal: CORS_LOG_REJECTS=true

# Con el mismo servicio Node sirviendo API + SPA (recomendado en Render: un solo Web Service),
# no hace falta si client/dist queda en ../client/dist respecto al server.
# CLIENT_DIST_PATH=

SESSION_SECRET=
SESSION_COOKIE_NAME=my_app_session
# Misma maquina sirve web + /api (un solo host): opcional SESSION_COOKIE_SAME_SITE=lax
# Front y API en hosts distintos (*.onrender.com distintos): NO uses lax — la cookie no se envia en fetch.
# En ese caso no definas SESSION_COOKIE_SAME_SITE (en prod queda none + Secure).
# SESSION_COOKIE_SAME_SITE=lax

MAIL_FROM=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=forum-uploads

GOOGLE_CLIENT_ID=

SUPERADMIN_EMAILS=
