DATABASE_URL=
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false

PORT=4000
CLIENT_ORIGIN=http://localhost:5174
# Produccion: lista extra si tenes mas de un origen (preview, app movil webview, etc.)
# CLIENT_ORIGINS=https://staging.example.com,https://app.example.com
# Si el front esta en muchos subdominios (ej. previews en Render), sin escribirlos todos:
# CLIENT_ORIGIN_REGEX=^https://[a-z0-9-]+\.onrender\.com$
# Ver en logs que Origin llego mal: CORS_LOG_REJECTS=true

# Con el mismo servicio Node sirviendo API + SPA (recomendado en Render: un solo Web Service),
# no hace falta si client/dist queda en ../client/dist respecto al server.
# CLIENT_DIST_PATH=

SESSION_SECRET=
SESSION_COOKIE_NAME=my_app_session
# Si el front y la API comparten el mismo dominio base (ej. www + api), proba lax en produccion (mejor Safari/iOS).
# SESSION_COOKIE_SAME_SITE=lax

MAIL_FROM=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=forum-uploads

GOOGLE_CLIENT_ID=

SUPERADMIN_EMAILS=

ANALYTICS_IP_DEDUPE_HOURS=24
