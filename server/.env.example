DATABASE_SSL_REJECT_UNAUTHORIZED=false

PORT=4000
CLIENT_ORIGIN=http://localhost:5174

SESSION_SECRET=
SESSION_COOKIE_NAME=my_app_session

MAIL_FROM=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=forum-uploads

GOOGLE_CLIENT_ID=

SUPERADMIN_EMAILS=

# Analytics: no nueva visita desde la misma IP dentro de esta ventana (horas). 0 = sin deduplicar por IP.
ANALYTICS_IP_DEDUPE_HOURS=24
