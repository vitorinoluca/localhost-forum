DATABASE_URL=
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false

PORT=4000

# URL del sitio en el navegador (no la del API si son distintos).
CLIENT_ORIGIN=http://localhost:5174

# Varias URLs separadas por coma (staging, etc.).
# CLIENT_ORIGINS=

# Regex para permitir orígenes sin listarlos uno a uno (previews).
# CLIENT_ORIGIN_REGEX=^https://[a-z0-9-]+\.onrender\.com$

# CLIENT_DIST_PATH=

SESSION_SECRET=
SESSION_COOKIE_NAME=my_app_session

# Si front y API están en dominios distintos, no fuerces lax (mejor omitir la variable).
# SESSION_COOKIE_SAME_SITE=lax

# AUTH_LOGIN_LOG=false

MAIL_FROM=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=forum-uploads

GOOGLE_CLIENT_ID=

SUPERADMIN_EMAILS=
