# Referencia unica del repo. En desarrollo: copia las variables VITE_* a client/.env y las del servidor a server/.env (Vite y Node no leen este archivo en la raiz por defecto).

# --- Cliente → pegar en client/.env ---
VITE_API_URL=
VITE_SITE_URL=https://example.com
VITE_SITE_NAME=localhost:forum
VITE_SITE_DESCRIPTION=
VITE_GOOGLE_CLIENT_ID=

# Opcional cliente (defaults en codigo si no las definis):
# VITE_THEME_COLOR=#0a0a0a
# VITE_SITE_KEYWORDS=
# VITE_OG_IMAGE_URL=
# VITE_OG_IMAGE_ALT=
# VITE_OG_LOCALE=es_ES
# VITE_TWITTER_SITE=
# VITE_TWITTER_CREATOR=
# VITE_SITE_AUTHOR=
# VITE_AD_LAYOUT_PREVIEW=false
# VITE_GOOGLE_ADSENSE_CLIENT=
# VITE_GOOGLE_ADSENSE_SLOT_TOP=
# VITE_GOOGLE_ADSENSE_SLOT_FEED=
# VITE_GOOGLE_ADSENSE_SLOT_ARTICLE=
# VITE_GOOGLE_ADSENSE_SLOT_PROFILE=
# VITE_CONTACT_EMAIL=
# VITE_SITE_OPERATOR_NAME=
# VITE_LEGAL_JURISDICTION=

# --- Servidor → pegar en server/.env ---
DATABASE_URL=
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false

PORT=4000
CLIENT_ORIGIN=http://localhost:5174

SESSION_SECRET=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=forum-uploads

GOOGLE_CLIENT_ID=

RESEND_API_KEY=
MAIL_FROM=onboarding@resend.dev

# Opcional servidor:
# SUPERADMIN_EMAILS=
# CLIENT_ORIGINS=
# CLIENT_ORIGIN_REGEX=
# CLIENT_DIST_PATH=
# SESSION_COOKIE_SAME_SITE=lax
# AUTH_LOGIN_LOG=false
# LISTEN_HOST=
